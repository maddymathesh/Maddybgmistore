# =============================================
# PASTE YOUR FIREBASE CONFIG VALUES HERE
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# =============================================

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# =============================================
# YOUR FIREBASE UID (Admin access)
# Get this from: Firebase Console → Authentication → Users (after first login)
# =============================================
VITE_ADMIN_UID=paste_your_firebase_uid_here
VITE_ADMIN_UID_2=paste_optional_second_admin_uid_here

# =============================================
# PAYMENT PAGE DISPLAY VALUES
# =============================================
VITE_PAYMENT_UPI_ID=maddyxpay@ybl
VITE_PAYMENT_PAYEE_NAME=MATHESHWARAN R

# =============================================
# FIREBASE FUNCTIONS ENVIRONMENT VARIABLES
# Set these for deployed functions, not in the Vite client bundle:
# firebase functions:secrets:set is also acceptable if you prefer secrets.
# =============================================
ADMIN_UID_1=paste_your_firebase_uid_here
ADMIN_UID_2=paste_optional_second_admin_uid_here
PAYMENT_BASE_URL=https://your-domain.com
