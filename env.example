VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Admin Authentication
VITE_ADMIN_UID=firebase_uid_of_admin_1
VITE_ADMIN_UID_2=firebase_uid_of_admin_2

# Supabase Configurations
