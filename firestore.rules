rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the requester is an authorized admin ──
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "paste_admin_1_firebase_uid_here" ||
        request.auth.uid == "paste_admin_2_firebase_uid_here"
      );
    }

    // ── products collection ────────────────────────────────────
    // Public: anyone can read (view stock listings)
    // Write: only admins can add / update / delete
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── reviews collection ─────────────────────────────────────
    // Public: anyone can read reviews
    // Write: public can create with validation, only admins can delete/update
    match /reviews/{docId} {
      allow read: if true;
      allow delete, update: if isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['name', 'rating', 'comment', 'uid'])
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 1
                    && request.resource.data.comment is string;
    }

    // ── globals collection (Review Stats) ──────────────────────
    match /globals/reviewStats {
      allow read: if true;
      // Allow the client transaction to update stats securely
      allow update: if request.auth != null
                    && request.resource.data.totalReviews is number
                    && request.resource.data.averageRating is number;
      // Allow initial creation if it doesn't exist
      allow create: if request.auth != null;
    }

    // ── Deny all other collections by default ──────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
