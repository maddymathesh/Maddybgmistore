rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the requester is an authorized admin ──
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "paste_admin_1_firebase_uid_here" ||
        request.auth.uid == "paste_admin_2_firebase_uid_here"
      );
    }

    // ── products collection ────────────────────────────────────
    // Public: anyone can read (view stock listings)
    // Write: only admins can add / update / delete
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── reviews collection ─────────────────────────────────────
    // Public: anyone can read reviews
    // Write: only admins can add / delete reviews
    match /reviews/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Deny all other collections by default ──────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
