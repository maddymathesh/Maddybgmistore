rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the requester is an authorized admin ──
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "yJDe1mSh28W1nfoVifZSomR6TiO2" ||
        request.auth.uid == "FOv8lMfou9cy6QPtaep5zF2qiP92" ||
        (
          'email' in request.auth.token &&
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email.toLowerCase()))
        )
      );
    }

    // ── products collection ────────────────────────────────────
    // Public: anyone can read (view stock listings)
    // Write: only admins can add / update / delete
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── reviews collection ─────────────────────────────────────
    // Public: anyone can read reviews
    // Write: public can create with validation, only admins can delete/update
    match /reviews/{docId} {
      allow read: if true;
      allow delete, update: if isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['name', 'rating', 'comment', 'uid'])
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 1
                    && request.resource.data.comment is string;
    }

    // ── globals collection (Review Stats) ──────────────────────
    match /globals/reviewStats {
      allow read: if true;
      // Allow the client transaction to update stats securely
      allow update: if request.auth != null
                    && request.resource.data.totalReviews is number
                    && request.resource.data.averageRating is number;
      // Allow initial creation if it doesn't exist
      allow create: if request.auth != null;
    }

    // ── payment_links collection ───────────────────────────────
    // Admin UI can list links; public checkout verification happens in Firebase Functions.
    match /payment_links/{docId} {
      allow read, write: if isAdmin();
    }

    match /payment_settings/{docId} {
      allow read, write: if isAdmin();
    }

    // ── admins collection ──────────────────────────────────────
    match /admins/{docId} {
      allow read: if request.auth != null && (isAdmin() || docId == request.auth.token.email.toLowerCase());
      allow write: if isAdmin();
    }

    // ── Deny all other collections by default ──────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
